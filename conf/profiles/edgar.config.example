executor {
    name = 'condor'
    pollInterval = '1 min'
    submitRateLimit = '1/20s'
    queueSize = 40
  }
process {
    clusterOptions = ['+AccountingGroup="g_compact.fkareem"']
    // DADA Process Configuration
    withLabel: 'dada_to_fits' {
        cpus           = 1
        memory        = '200 GB'
        clusterOptions = ['+AccountingGroup="g_compact.fkareem"', 'request_gpus = 1']
    }

    // Filtool Process Configuration
    withLabel: 'filtool' {
        cpus           = 20  // Use the maximum available CPUs on Edgar or however many are needed
        // make sure that threads and cpus are the same
        memory         = '200 GB'
        time           = '24h'
    }

    // Parse XML Process Configuration
    withLabel: 'parse_xml' {
        cpus       = 1
        memory     = '5 GB'
        time       = '15m'
    }

    // Peasoup Process Configuration
    withLabel: 'peasoup' {
        cpus           = 1
        memory         = '150 GB'
        clusterOptions = ['+AccountingGroup="g_compact.fkareem"', 'request_gpus = 1']
    }

    withLabel: 'birdies' {
        cpus           = 1
        memory         = '100 GB'
        clusterOptions = ['+AccountingGroup="g_compact.fkareem"', 'request_gpus = 1']
    }

    // palClean Process Configuration (GPU RFI cleaning via pal-clean CUDA pipeline)
    withLabel: 'pal_clean' {
        cpus           = 10
        memory         = '100 GB'
        clusterOptions = ['+AccountingGroup="g_compact.fkareem"', 'request_gpus = 1']
    }

    // followup_peasoup Process Configuration (GPU periodicity search)
    withLabel: 'followup_peasoup' {
        cpus           = 1
        memory         = '150 GB'
        clusterOptions = ['+AccountingGroup="g_compact.fkareem"', 'request_gpus = 1']
    }

    // Followup CPU processes
    withLabel: 'followup_prepare' {
        cpus           = 1
        memory         = '10 GB'
    }

    withLabel: 'followup_match' {
        cpus           = 1
        memory         = '10 GB'
    }

    withLabel: 'followup_fold' {
        cpus           = 20
        memory         = '200 GB'
    }

    // PsrFold Process Configuration
    withLabel: 'psrfold' {
        cpus           = 60
        memory         = '500 GB'
    }

    // Pics Classifier Process Configuration
    withLabel: 'pics_classifier' {
        cpus       = 20
        memory     = '200 GB'
        time       = '4h'
    }

    // Splitcands Process Configuration
    withLabel: 'splitcands' {
        cpus       = 1
        memory     = '10 GB'
    }

    // Readfile Process Configuration
    withLabel: 'readfile' {
        cpus           = 1
        memory         = '10 GB'
    }

    // Generate RFI Filter Process Configuration
    withLabel: 'generate_rfi_filter' {
        cpus           = 60
        memory         = '600 GB'
    }

    // Nearest Power of Two Calculator Process Configuration
    withLabel: 'nearest_power_two_calculator' {
        cpus       = 1
        memory     = '10 GB'
    }

    // Generate DM Files Process Configuration
    withLabel: 'generateDMFiles' {
        cpus       = 1
        memory     = '10 GB'
    }

    // for parfold
    withLabel: 'parfold' {
        cpus           = 20
        memory         = '200 GB'
        errorStrategy = 'ignore'
    }

    // search_fold_merge Process Configuration
    withLabel: 'search_fold_merge' {
        cpus       = 1
        memory     = '5 GB'
        time       = '15m'
    }

    // alpha_beta_gamma_test Process Configuration
    withLabel: 'alpha_beta_gamma_test' {
        cpus       = 4
        memory     = '20 GB'
        time       = '1h'
    }

    // split_filterbank Process Configuration
    withLabel: 'split_filterbank' {
        cpus       = 1
        memory     = '20 GB'
        time       = '1h'
    }

    // merge_filterbanks Process Configuration
    withLabel: 'merge_filterbanks' {
        cpus       = 1
        memory     = '100 GB'
        time       = '12h'
    }

    // segmented_params Process Configuration
    withLabel: 'segmented_params' {
        cpus       = 1
        memory     = '10 GB'
        time       = '15m'
    }

    // candypolice_pulsarx Process Configuration
    withLabel: 'candypolice_pulsarx' {
        cpus           = 20
        memory         = '200 GB'
        time           = '4h'
    }

    // candypolice_presto Process Configuration
    withLabel: 'candypolice_presto' {
        cpus           = 8
        memory         = '64 GB'
        time           = '4h'
    }
}

// Define container image paths specific to Edgar cluster
params {
    // Container images for Edgar
    singularity_image_dir = "/fpra/timing/01/fazal/singularity_img"
    pulsarx_image         = "${params.singularity_image_dir}/pulsarx_latest.sif"
    presto_image          = "${params.singularity_image_dir}/presto4.sif"
    peasoup_image         = "${params.singularity_image_dir}/peasoup_keplerian.sif"
    psrchive_image        = "${params.singularity_image_dir}/trapum_pulsarx_fold_docker_20220411.sif"
    rfi_mitigation_image  = "${params.singularity_image_dir}/rfi-mitigation-nextflow_amd64.sif"
    presto5_image         = "${params.singularity_image_dir}/presto5_pddot.sif"
    pics_classifier_image = "${params.singularity_image_dir}/trapum_pulsarx_fold_docker_20220411.sif"
    edd_pulsar_image      = "${params.singularity_image_dir}/edd_pulsar_250626.0.sif"
    filtools_sig_image    = "${params.singularity_image_dir}/filtools-image_sig.sif"
    pal_clean_image       = "${params.singularity_image_dir}/pal_latest.sif"
    rusty_candypicker     = "${params.singularity_image_dir}/rusty_candypicker_latest.sif"

    // Number of threads for processes
    threads = 20  // Adjust as per the Edgar cluster's CPU availability

    // Update splitcands threads
    splitcands {
        threads = 20
    }
}

// Singularity configuration for Edgar
apptainer {
        enabled = true
        runOptions = '-B /fpra -B /bEDD -B /homes --nv'
        envWhitelist = 'APPTAINER_BINDPATH, APPTAINER_LD_LIBRARY_PATH'
    }

// Report and trace settings
report {
    overwrite = true
}

trace {
    overwrite = true
}
